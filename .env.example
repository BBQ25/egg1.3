APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_WEB_PATH=
LOGIN_CLICK_BYPASS_ALLOWED=true
LOGIN_CLICK_BYPASS_ENABLED=true
LOGIN_CLICK_BYPASS_ADMIN_USERNAME=admin
LOGIN_CLICK_BYPASS_ADMIN_WINDOW=3
LOGIN_CLICK_BYPASS_OWNER_USERNAME=
LOGIN_CLICK_BYPASS_OWNER_WINDOW=3
LOGIN_CLICK_BYPASS_STAFF_USERNAME=
LOGIN_CLICK_BYPASS_STAFF_WINDOW=3

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

